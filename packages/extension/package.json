{
  "name": "@backbrain/extension",
  "version": "0.1.0",
  "private": true,
  "displayName": "BackBrain",
  "description": "AI-Powered Code Security & Quality Platform",
  "publisher": "backbrain",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Testing"
  ],
  "activationEvents": [
    "onView:backbrain.severityPanel",
    "onCommand:backbrain.scanFile",
    "onCommand:backbrain.scanWorkspace",
    "onCommand:backbrain.showSecurityPanel",
    "onCommand:backbrain.explainIssue",
    "onCommand:backbrain.suggestFix",
    "onCommand:backbrain.generateReport",
"onCommand:backbrain.setApiKey",
    "onCommand:backbrain.loginGemini",
    "onCommand:backbrain.logoutGemini"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "backbrain.scanFile",
        "title": "BackBrain: Scan Current File"
      },
      {
        "command": "backbrain.scanWorkspace",
        "title": "BackBrain: Scan Workspace"
      },
      {
        "command": "backbrain.showSecurityPanel",
        "title": "BackBrain: Show Security Panel"
      },
      {
        "command": "backbrain.explainIssue",
        "title": "BackBrain: Explain Issue with AI"
      },
      {
        "command": "backbrain.suggestFix",
        "title": "BackBrain: Suggest Fix with AI"
      },
      {
        "command": "backbrain.generateReport",
        "title": "BackBrain: Generate Security Report"
      },
      {
        "command": "backbrain.setApiKey",
        "title": "BackBrain: Set AI API Key"
      },
      {
        "command": "backbrain.loginGemini",
        "title": "BackBrain: Login to Gemini CLI"
      },
      {
        "command": "backbrain.logoutGemini",
        "title": "BackBrain: Logout from Gemini CLI"
      }
    ],
    "configuration": {
      "title": "BackBrain",
      "properties": {
        "backbrain.scanOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan files on save"
        },
        "backbrain.excludePaths": {
          "type": "array",
          "default": [
            "node_modules",
            "bower_components",
            "jspm_packages",
            ".pnpm",
            ".yarn",
            "dist",
            "build",
            ".git",
            "out",
            "coverage",
            "vendor",
            ".venv",
            "venv",
            "env",
            ".tox",
            "__pypackages__",
            "site-packages",
            ".gradle",
            ".m2",
            "target",
            "Pods",
            "Carthage",
            "DerivedData"
          ],
          "description": "Paths to exclude from scanning"
        },
        "backbrain.autoScan": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan files on open/save"
        },
        "backbrain.scanOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Trigger a full workspace scan when the extension activates"
        },
        "backbrain.enabledScanners": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "semgrep",
              "gitleaks",
              "trivy",
              "osv-scanner",
              "vibe-code",
              "tree-sitter"
            ]
          },
          "default": [
            "semgrep",
            "gitleaks",
            "trivy",
            "osv-scanner",
            "vibe-code",
            "tree-sitter"
          ],
          "description": "Deterministic scanners enabled for BackBrain scans"
        },
        "backbrain.ai.provider": {
          "type": "string",
          "enum": [
            "openai",
            "anthropic",
            "google",
            "xai",
            "deepseek",
            "nvidia",
            "openrouter"
          ],
          "default": "openai",
          "description": "Selected AI provider for explanations and fix suggestions"
        },
        "backbrain.ai.model": {
          "type": "string",
          "default": "",
          "description": "Model to use for the selected provider (leave empty for default)"
        },
        "backbrain.ai.contextLines": {
          "type": "number",
          "default": 15,
          "description": "Number of surrounding lines to include as context for AI requests"
        },
        "backbrain.ai.useStreaming": {
          "type": "boolean",
          "default": true,
          "description": "Use streaming for AI responses in the output channel"
        },
        "backbrain.ai.agentReviewEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable dynamic AI agent review after deterministic scanners finish"
        },
        "backbrain.ai.agentReviewScope": {
          "type": "string",
          "enum": [
            "workspace",
            "changed-files",
            "both"
          ],
          "default": "both",
          "description": "Scope AI agent review to the full workspace, changed files only, or both"
        },
        "backbrain.ai.agentBackends": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "codex",
              "gemini",
              "opencode"
            ]
          },
          "default": [
            "codex",
            "gemini",
            "opencode"
          ],
          "description": "Allowed CLI backends for AI agent review"
        },
        "backbrain.ai.agentPreferredBackend": {
          "type": "string",
          "enum": [
            "codex",
            "gemini",
            "opencode"
          ],
          "default": "codex",
          "description": "Preferred CLI backend to use first for AI agent review"
        },
        "backbrain.ai.agentScanDepth": {
          "type": "string",
          "enum": [
            "developer",
            "team",
            "security",
            "audit"
          ],
          "enumDescriptions": [
            "Quick feedback during active development. Ensures free tier users don't hit rate limits.",
            "Pre-commit review before pushing.",
            "Security-conscious review of sensitive code.",
            "Full spectrum audit before release or compliance gate."
          ],
          "default": "developer",
          "description": "Control how thorough the agentic scan is. Higher tiers use more AI calls and take longer."
        },
        "backbrain.ai.maxAgentSpecialists": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "maximum": 12,
          "description": "Maximum number of specialist agents the lead planner may create",
          "deprecationMessage": "Use backbrain.ai.agentScanDepth instead."
        },
        "backbrain.ai.agentSpecialistConcurrency": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 12,
          "description": "Maximum number of AI specialist reviewers to run in parallel",
          "deprecationMessage": "Use backbrain.ai.agentScanDepth instead."
        },
        "backbrain.ai.agentBinaryPathCodex": {
          "type": "string",
          "default": "",
          "description": "Optional override path for the Codex CLI binary"
        },
        "backbrain.ai.agentCodexModel": {
          "type": "string",
          "default": "",
          "description": "Optional Codex model override for AI agent review"
        },
        "backbrain.ai.agentBinaryPathGemini": {
          "type": "string",
          "default": "",
          "description": "Optional override path for the Gemini CLI binary"
        },
        "backbrain.ai.agentBinaryPathOpencode": {
          "type": "string",
          "default": "",
          "description": "Optional override path for the OpenCode CLI binary"
        },
        "backbrain.ai.agentOpencodeModel": {
          "type": "string",
          "default": "",
          "description": "Optional model override for OpenCode agent review (format: provider/model)"
        },
        "backbrain.ai.agentOpencodeVariant": {
          "type": "string",
          "default": "",
          "description": "Optional reasoning effort variant for OpenCode (e.g., high, max, minimal)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "backbrain-sidebar",
          "title": "BackBrain",
          "icon": "media/backbrain.svg"
        }
      ]
    },
    "views": {
      "backbrain-sidebar": [
        {
          "type": "webview",
          "id": "backbrain.severityPanel",
          "name": "Security Issues",
          "icon": "$(shield)"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsup && cp -f ../core/node_modules/web-tree-sitter/tree-sitter.wasm dist/ && cp -f ../core/node_modules/tree-sitter-javascript/tree-sitter-javascript.wasm dist/ && cp -f ../core/node_modules/tree-sitter-typescript/tree-sitter-typescript.wasm dist/ && cp -f ../core/node_modules/tree-sitter-typescript/tree-sitter-tsx.wasm dist/ && bun run build:webview",
    "build:webview": "vite build",
    "watch": "tsup --watch",
    "typecheck": "tsc --noEmit && tsc -p src/webview/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@backbrain/core": "workspace:*",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "handlebars": "^4.7.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "web-tree-sitter": "0.22.6"
  },
  "devDependencies": {
    "@types/handlebars": "^4.1.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.2.0",
    "tsup": "^8.0.1",
    "vite": "^5.0.0"
  }
}
